package servletapp;

import java.io.IOException;
import java.io.PrintWriter;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.SQLException;

import jakarta.servlet.ServletContext;
import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;

@WebServlet("/third")
public class ThirdServlet extends HttpServlet{
	@Override
	protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
		System.out.println("Inside Third Servlet");
		
		int roll = Integer.parseInt(req.getParameter("roll"));
		String firstname = req.getParameter("firstname");
		String city = req.getParameter("city");
		System.out.println(roll + " " + firstname + " " + city);
		
		// JDBC
		
		try {
			Class.forName("com.mysql.cj.jdbc.Driver");
		}catch(ClassNotFoundException e) {
			    e.printStackTrace();
		}
		
		String url = "jdbc:mysql://localhost:3306/parul";
		try {
		Connection conn = DriverManager.getConnection(url, "root", "ansh2712");
		
		PreparedStatement st = conn.prepareStatement("insert into student values(?, ?, ?)");
		st.setInt(1 ,roll);
		st.setString(2, firstname);
		st.setString(3, city);
		
		st.executeUpdate();
		
		PrintWriter wr = resp.getWriter();
		wr.write("Student added successfully");
		
		// SERVLET CONTEXT
		ServletContext ctx = getServletContext();
		ctx.setAttribute("uni", "parul");
		
		} 
		catch(SQLException e){
			e.printStackTrace();
		}
	}
}
